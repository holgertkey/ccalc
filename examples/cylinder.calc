% Cylinder volume and surface area
% V = pi * r^2 * h
% A = 2 * pi * r * (r + h)
%
% Usage: ccalc cylinder.ccalc

r = 5;                    % radius
h = 10;                   % height

base_area = pi * r^2;     % pi * r^2

fprintf('Volume: %.2f\n', base_area * h)
fprintf('Surface area: %.2f\n', 2 * base_area + 2 * pi * r * h)
