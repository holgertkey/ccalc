% Cylinder volume and surface area
% V = pi * r^2 * h
% A = 2 * pi * r * (r + h)
%
% Usage: ccalc cylinder.ccalc

r = 5;                    % radius
h = 10;                   % height

base_area = pi * r^2;     % pi * r^2

base_area * h;
fprintf('Volume: ')
disp(ans)

2 * base_area + 2 * pi * r * h;
fprintf('Surface area: ')
disp(ans)
